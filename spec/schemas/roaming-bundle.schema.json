{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://statebridge-protocol.github.io/sbp/schemas/roaming-bundle.schema.json",
  "title": "SBP Roaming Bundle",
  "description": "The full exported state of a session. Stored server-side; the Roaming Token is a reference to it. This is the v1.0 bundle format (independent version from the wire protocol).",
  "type": "object",
  "required": ["sbp_version", "exported_at", "session", "messages", "memory", "metadata"],
  "properties": {
    "sbp_version": {
      "type": "string",
      "description": "Bundle format version. Currently '1.0'. Independent from wire version.",
      "const": "1.0"
    },
    "exported_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of export."
    },
    "label": {
      "type": ["string", "null"],
      "maxLength": 120,
      "description": "Optional human-readable label for this export."
    },
    "session": {
      "type": "object",
      "required": ["id", "agent_external_id", "status", "created_at", "step_count"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "agent_external_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["idle", "running", "suspended", "completed", "failed"]
        },
        "last_task": { "type": ["string", "null"] },
        "created_at": { "type": "string", "format": "date-time" },
        "step_count": { "type": "integer", "minimum": 0 }
      }
    },
    "messages": {
      "type": "array",
      "description": "Full conversation history in chronological order.",
      "items": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
          "content": { "type": ["string", "null"] },
          "model_used": { "type": ["string", "null"] },
          "cost_usd": { "type": ["number", "null"] },
          "created_at": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "memory": {
      "type": "object",
      "description": "Memory bundle. schema_id identifies the payload format; payload is opaque to the protocol. Implementations that do not recognize schema_id MUST import without memory rather than rejecting the bundle.",
      "required": ["schema_id"],
      "properties": {
        "schema_id": {
          "type": "string",
          "description": "URI identifying the memory schema. Registered schemas are listed in SPEC.md §15.2.",
          "examples": ["silkbridge.memory.v1", "custom.memory.v1"]
        },
        "payload": {
          "type": "object",
          "description": "Opaque memory object. Structure defined by schema_id."
        }
      }
    },
    "state_snapshot": {
      "type": ["object", "null"],
      "description": "Latest agent state snapshot. May be null if no snapshot exists."
    },
    "metadata": {
      "type": "object",
      "required": ["export_id", "message_count"],
      "properties": {
        "export_id": { "type": "string", "format": "uuid" },
        "message_count": { "type": "integer", "minimum": 0 },
        "total_cost_usd": { "type": ["number", "null"] }
      }
    }
  }
}
