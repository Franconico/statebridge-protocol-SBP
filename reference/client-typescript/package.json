{
  "name": "@statebridge/sbp-client",
  "version": "0.9.0",
  "description": "State Bridge Protocol (SBP) v0.9 reference client — TypeScript/browser/Node",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": ["sbp", "statebridge", "ai", "agents", "protocol", "websocket"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/statebridge-protocol/sbp"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
